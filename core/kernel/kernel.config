# CookieOS Hardened Kernel Configuration
# Based on linux-hardened / GrapheneOS kernel patches
# Target: x86_64 + ARM64
# Run: scripts/apply-kernel-config.sh to merge with upstream defconfig

# ── Compiler hardening ───────────────────────────────────────────────────────
CONFIG_CC_IS_GCC=n
CONFIG_CC_IS_CLANG=y
CONFIG_CFI_CLANG=y                        # Control Flow Integrity (Clang)
CONFIG_CFI_PERMISSIVE=n
CONFIG_SHADOW_CALL_STACK=y               # Shadow call stack (ARM64)
CONFIG_INIT_STACK_ALL_ZERO=y             # Zero init all stack vars
CONFIG_ZERO_CALL_USED_REGS=y            # Zero regs on function exit
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_STACKPROTECTOR=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_UBSAN=y
CONFIG_UBSAN_TRAP=y
CONFIG_UBSAN_BOUNDS=y
CONFIG_UBSAN_BOOL=n
CONFIG_UBSAN_ENUM=n
CONFIG_UBSAN_ALIGNMENT=n
CONFIG_SANCOV_TRACE_PC=n

# ── Memory safety ────────────────────────────────────────────────────────────
CONFIG_SLAB_FREELIST_RANDOM=y
CONFIG_SLAB_FREELIST_HARDENED=y
CONFIG_SHUFFLE_PAGE_ALLOCATOR=y
CONFIG_RANDOMIZE_BASE=y                  # KASLR
CONFIG_RANDOMIZE_MEMORY=y               # KASLR memory regions
CONFIG_VMAP_STACK=y                      # Virtually mapped stacks
CONFIG_GCC_PLUGIN_STACKLEAK=y           # Erase kernel stack on syscall
CONFIG_INIT_ON_ALLOC_DEFAULT_ON=y       # Zero alloc on init
CONFIG_INIT_ON_FREE_DEFAULT_ON=y        # Zero free on init
CONFIG_PAGE_SANITIZE=y
CONFIG_KASAN=n                           # Disabled in production (perf)
CONFIG_HARDENED_USERCOPY=y
CONFIG_HARDENED_USERCOPY_FALLBACK=n
CONFIG_STRICT_DEVMEM=y
CONFIG_IO_STRICT_DEVMEM=y
CONFIG_ARCH_MMAP_RND_BITS_MAX=32
CONFIG_ARCH_MMAP_RND_COMPAT_BITS_MAX=16

# ── Kernel self protection ───────────────────────────────────────────────────
CONFIG_SECURITY=y
CONFIG_SECURITY_YAMA=y                   # ptrace scope restrictions
CONFIG_SECURITY_APPARMOR=y
CONFIG_SECURITY_SELINUX=y
CONFIG_DEFAULT_SECURITY_APPARMOR=y
CONFIG_LOCKDOWN_LSM=y
CONFIG_LOCK_DOWN_KERNEL_FORCE_CONFIDENTIALITY=y
CONFIG_SECURITY_LOCKDOWN_LSM=y
CONFIG_MODULE_SIG=y
CONFIG_MODULE_SIG_FORCE=y
CONFIG_MODULE_SIG_SHA512=y
CONFIG_STRICT_MODULE_RWX=y
CONFIG_DEBUG_WX=y
CONFIG_RODATA_FULL_DEFAULT_ENABLED=y

# ── Disable dangerous features ───────────────────────────────────────────────
CONFIG_ACPI_CUSTOM_METHOD=n
CONFIG_COMPAT_BRK=n
CONFIG_DEVKMEM=n                         # No /dev/kmem
CONFIG_PROC_KCORE=n                      # No /proc/kcore
CONFIG_LEGACY_PTYS=n
CONFIG_HIBERNATION=n                     # Hibernation leaks memory to disk
CONFIG_BINFMT_MISC=n                     # Reduce attack surface
CONFIG_LIVEPATCH=n
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y
CONFIG_BPF_UNPRIV_DEFAULT_OFF=y
CONFIG_UNPRIVILEGED_USERNS=n             # No unpriv user namespaces

# ── Network hardening ────────────────────────────────────────────────────────
CONFIG_SYN_COOKIES=y
CONFIG_NET_IPGRE_DEMUX=n
CONFIG_IP_DCCP=n
CONFIG_IP_SCTP=n
CONFIG_RDS=n
CONFIG_TIPC=n
CONFIG_ATM=n
CONFIG_DECNET=n
CONFIG_ECONET=n
CONFIG_WAN_ROUTER=n
CONFIG_NET_VENDOR_XIRCOM=n
CONFIG_NETFILTER=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_TABLES=y
CONFIG_NETFILTER_XTABLES=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP6_NF_FILTER=y
CONFIG_TCP_CONG_BBR=y
CONFIG_DEFAULT_TCP_CONG="bbr"

# ── Filesystem hardening ─────────────────────────────────────────────────────
CONFIG_EXT4_FS=y
CONFIG_EXT4_ENCRYPTION=y
CONFIG_F2FS_FS=y
CONFIG_F2FS_FS_ENCRYPTION=y
CONFIG_FS_ENCRYPTION=y
CONFIG_FS_VERITY=y                       # dm-verity for read-only images
CONFIG_DM_CRYPT=y
CONFIG_DM_INTEGRITY=y
CONFIG_DM_VERITY=y
CONFIG_DM_VERITY_VERIFY_ROOTHASH_SIG=y
CONFIG_EROFS_FS=y                        # Read-only compressed FS (Android)
CONFIG_OVERLAY_FS=y                      # For container/sandbox support
CONFIG_PROC_FS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_XATTR=y

# ── Trusted Platform Module ──────────────────────────────────────────────────
CONFIG_TCG_TPM=y
CONFIG_TCG_TIS=y
CONFIG_TCG_TIS_SPI=y
CONFIG_TRUSTED_KEYS=y
CONFIG_ENCRYPTED_KEYS=y

# ── Hardware features ────────────────────────────────────────────────────────
CONFIG_INTEL_IOMMU=y
CONFIG_INTEL_IOMMU_DEFAULT_ON=y
CONFIG_AMD_IOMMU=y
CONFIG_IOMMU_DEFAULT_PASSTHROUGH=n
CONFIG_IOMMU_DEFAULT_DMA_STRICT=y       # Block DMA attacks
CONFIG_IOMMU_SUPPORT=y
CONFIG_MICROCODE=y
CONFIG_MICROCODE_INTEL=y
CONFIG_MICROCODE_AMD=y
CONFIG_RETPOLINE=y                       # Spectre v2 mitigation
CONFIG_PAGE_TABLE_ISOLATION=y           # Meltdown mitigation
CONFIG_SPECULATION_MITIGATIONS=y

# ── Audit and integrity ──────────────────────────────────────────────────────
CONFIG_AUDIT=y
CONFIG_AUDITSYSCALL=y
CONFIG_IMA=y                             # Integrity Measurement Architecture
CONFIG_IMA_DEFAULT_HASH="sha256"
CONFIG_IMA_WRITE_POLICY=n
CONFIG_EVM=y
CONFIG_EVM_DEFAULT_HMAC_ALGO="hmac(sha256)"
